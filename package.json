{
  "name": "yicai-packaging",
  "version": "1.0.0",
  "private": true,
  "description": "溢彩包装 — EVA 片材包装生产控制系统",
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "cd server && pnpm dev",
    "dev:client": "cd client && pnpm dev",
    "build": "cd client && pnpm build",
    "start": "cd server && pnpm start"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "packageManager": "pnpm@10.33.2"
}
